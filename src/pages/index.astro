---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body data-pagefind-ignore>
		<Header />
		<main>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`${post.data.slug}`} class="post-link">
							<div class="post-text">
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-meta">
									{formatDate(post.data.pubDate)}
	
								</p>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</div>
							{post.data.heroImage && (
								<div class="post-cover">
									<Image
										src={post.data.heroImage}
										alt=""
										width={320}
									/>
								</div>
							)}
						</a>
						<hr />
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 2.5rem 1.5rem;
	}
	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	li hr {
		margin: 0;
	}
	li:last-child hr {
		display: none;
	}
	.post-link {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
		padding: 1.75rem 0;
		text-decoration: none;
		color: inherit;
	}
	.post-link:hover {
		text-decoration: none;
	}
	.post-link:hover .post-title {
		color: var(--accent);
	}
	.post-text {
		flex: 1;
		min-width: 0;
	}
	.post-title {
		margin: 0 0 0.35rem;
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text);
		line-height: 1.35;
		transition: color 0.15s;
	}
	.post-meta {
		margin: 0 0 0.5rem;
		font-size: 0.82rem;
		color: var(--text-muted);
	}
	.post-desc {
		margin: 0;
		font-size: 0.9rem;
		color: var(--text-muted);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post-cover {
		flex-shrink: 0;
		width: 320px;
	}
	.post-cover img {
		width: 320px;
		height: auto;
		border-radius: 6px;
		display: block;
	}
	@media (max-width: 520px) {
		.post-link { flex-direction: column-reverse; }
		.post-cover { width: 100%; }
		.post-cover img { width: 100%; }
		.post-desc { display: block; }
	}
</style>

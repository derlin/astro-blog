---
import { Image } from 'astro:assets';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { headings: MarkdownHeading[] };

const { title, description, pubDate, updatedDate, heroImage, headings } = Astro.props;

const displayDate = updatedDate ?? pubDate;
const dateLabel = updatedDate ? 'Updated' : 'Published';

const tocHeadings = headings
	.filter(h => h.depth <= 3)
	.map(h => ({ ...h, text: h.text.replace(/^#+\s*/, '') }));

function formatDate(date: Date) {
	return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="article-top">
				<div class="article-header">
					<h1>{title}</h1>
					<p class="article-meta">
						{dateLabel} {formatDate(displayDate)}
	
					</p>
				</div>
				{heroImage && (
					<div class="hero-image">
						<Image src={heroImage} alt="" width={820} height={380} />
					</div>
				)}

			</div>

			<div class="article-body">
				<aside class="toc-sidebar" aria-label="Table of contents">
					{tocHeadings.length > 0 && (
						<nav class="toc">
							<p class="toc-title">On this page</p>
							<ul>
								{tocHeadings.map(h => (
									<li class={`toc-h${h.depth}`}>
										<a href={`#${h.slug}`} data-toc-slug={h.slug}>{h.text}</a>
									</li>
								))}
							</ul>
						</nav>
					)}
				</aside>

				<article class="prose">
					<slot />
				</article>

				<div class="toc-spacer" aria-hidden="true"></div>
			</div>
		</main>
		<Footer />

		{tocHeadings.length > 0 && (
			<>
				<button class="toc-fab" id="toc-fab" aria-label="Table of contents">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<line x1="3" y1="6" x2="21" y2="6"/>
						<line x1="3" y1="12" x2="15" y2="12"/>
						<line x1="3" y1="18" x2="18" y2="18"/>
					</svg>
				</button>
				<div class="toc-overlay" id="toc-overlay" aria-hidden="true">
					<div class="toc-drawer" id="toc-drawer">
						<div class="toc-drawer-header">
							<span>On this page</span>
							<button class="toc-close" id="toc-close" aria-label="Close">✕</button>
						</div>
						<ul>
							{tocHeadings.map(h => (
								<li class={`toc-h${h.depth}`}>
									<a href={`#${h.slug}`} class="toc-drawer-link">{h.text}</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</>
		)}
	</body>
</html>

<style>
	main {
		padding: 2.5rem 1.5rem 4rem;
	}
	.article-top {
		max-width: 820px;
		margin: 0 auto;
	}
	.article-body {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		gap: 2.5rem;
	}
	.toc-sidebar {
		width: 220px;
		flex-shrink: 0;
		position: sticky;
		top: 5rem;
		max-height: calc(100vh - 6rem);
		overflow-y: auto;
		padding-top: 1em;
	}
	.toc-spacer {
		width: 220px;
		flex-shrink: 0;
	}
	.toc {
		font-size: 0.82rem;
		line-height: 1.4;
	}
	.toc-title {
		font-weight: 700;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin: 0 0 0.75rem;
	}
	.toc ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.toc li {
		margin-bottom: 0.35rem;
	}
	.toc-h3 {
		padding-left: 0.85rem;
	}
	.toc a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
		display: block;
	}
	.toc a:hover,
	.toc a.active {
		color: var(--accent);
	}
	/* Mobile FAB + overlay */
	.toc-fab {
		display: none;
		position: fixed;
		bottom: 1.5rem;
		right: 1.5rem;
		z-index: 100;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: var(--accent);
		color: #fff;
		border: none;
		cursor: pointer;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 16px rgba(0,0,0,0.4);
		transition: background 0.15s;
	}
	.toc-fab:hover { background: var(--accent-hover); }
	.toc-overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
		background: rgba(0,0,0,0.5);
	}
	.toc-overlay.open { display: block; }
	.toc-drawer {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: var(--bg-surface);
		border-top: 1px solid var(--border);
		border-radius: 16px 16px 0 0;
		padding: 1.25rem 1.5rem 2rem;
		max-height: 70vh;
		overflow-y: auto;
	}
	.toc-drawer-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		font-weight: 700;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
	}
	.toc-close {
		background: none;
		border: none;
		color: var(--text-muted);
		cursor: pointer;
		font-size: 1rem;
		padding: 0;
		line-height: 1;
	}
	.toc-drawer ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.toc-drawer li {
		margin-bottom: 0.6rem;
	}
	.toc-drawer .toc-h3 {
		padding-left: 1rem;
	}
	.toc-drawer-link {
		color: var(--text);
		text-decoration: none;
		font-size: 0.95rem;
	}
	.toc-drawer-link:hover { color: var(--accent); }
	/* Article */
	.prose {
		min-width: 0;
		width: 820px;
		max-width: 100%;
		font-size: 1.1rem;
		line-height: 1.5;
	}
	.article-header {
		text-align: center;
		margin-bottom: 2rem;
	}
	.article-header h1 {
		font-size: 2.25rem;
		font-weight: 800;
		line-height: 1.2;
		margin: 0 0 0.75rem;
		color: var(--text);
	}
	.article-meta {
		margin: 0;
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.hero-image {
		margin: 0 -4rem 2.5rem;
		border-radius: 10px;
		overflow: hidden;
	}
	.hero-image img {
		width: 100%;
		height: auto;
		max-height: 460px;
		object-fit: cover;
		border-radius: 10px;
		display: block;
	}
	@media (max-width: 860px) {
		.hero-image { margin-left: -1.5rem; margin-right: -1.5rem; border-radius: 0; }
		.hero-image img { border-radius: 0; }
	}
	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		position: relative;
		scroll-margin-top: 80px;
	}
	.prose :global(.anchor) {
		position: absolute;
		left: -1.25em;
		top: 50%;
		transform: translateY(-50%);
		color: var(--text-muted);
		opacity: 0;
		text-decoration: none;
		font-weight: 400;
		transition: opacity 0.15s;
		font-size: 0.9em;
	}
	.prose :global(h2:hover .anchor),
	.prose :global(h3:hover .anchor),
	.prose :global(h4:hover .anchor) {
		opacity: 1;
	}
	.prose :global(h2) {
		margin-top: 2em;
		font-size: 1.5rem;
	}
	.prose :global(h3) {
		margin-top: 1.75em;
		font-size: 1.2rem;
	}
	.prose :global(img) {
		display: block;
		max-width: 100%;
		border-radius: 6px;
		margin: 1em auto;
	}
	.prose :global(img.img-left) {
		margin-left: 0;
		margin-right: auto;
	}
	.prose :global(a) {
		color: var(--accent);
	}
	.prose :global(a:hover) {
		color: var(--accent-hover);
	}
	@media (max-width: 1100px) {
		.toc-sidebar,
		.toc-spacer { display: none; }
		.toc-fab { display: flex; }
	}
	@media (max-width: 600px) {
		.article-header h1 { font-size: 1.6rem; }
	}
</style>

<script>
	// Scroll spy
	const links = document.querySelectorAll<HTMLAnchorElement>('.toc a[data-toc-slug]');
	if (links.length) {
		const headingEls = Array.from(links).map(l =>
			document.getElementById(l.dataset.tocSlug!)
		).filter(Boolean) as HTMLElement[];

		const observer = new IntersectionObserver(entries => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					links.forEach(l => l.classList.remove('active'));
					const link = document.querySelector<HTMLAnchorElement>(
						`.toc a[data-toc-slug="${entry.target.id}"]`
					);
					link?.classList.add('active');
				}
			}
		}, { rootMargin: '0px 0px -70% 0px', threshold: 0 });

		headingEls.forEach(el => observer.observe(el));
	}

	// Mobile FAB
	const fab = document.getElementById('toc-fab');
	const overlay = document.getElementById('toc-overlay');
	const closeBtn = document.getElementById('toc-close');

	function openDrawer() {
		overlay?.classList.add('open');
		overlay?.setAttribute('aria-hidden', 'false');
	}
	function closeDrawer() {
		overlay?.classList.remove('open');
		overlay?.setAttribute('aria-hidden', 'true');
	}

	fab?.addEventListener('click', openDrawer);
	closeBtn?.addEventListener('click', closeDrawer);
	overlay?.addEventListener('click', (e) => {
		if (e.target === overlay) closeDrawer();
	});
	document.querySelectorAll('.toc-drawer-link').forEach(a =>
		a.addEventListener('click', closeDrawer)
	);
</script>
